[Unit]
Description=FrogsWork File Storage API
After=network-online.target
Wants=network-online.target
RequiresMountsFor=/data

[Service]
Type=simple
User=frogswork
Group=frogswork
RuntimeDirectory=frogswork
RuntimeDirectoryMode=0750
WorkingDirectory=/opt/frogswork/backend
Environment=PYTHONUNBUFFERED=1
ExecStart=/opt/frogswork/venv/bin/uvicorn frogswork_api.main:app --uds /run/frogswork/api.sock --umask 007
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
