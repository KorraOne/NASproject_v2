<Window x:Class="FrogsWork.Helper.UI.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FrogsWork — Connect"
        Height="380"
        Width="440"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
  <StackPanel Margin="20">
    <TextBlock FontSize="20" FontWeight="SemiBold" Text="Connect to FrogsWork" />
    <TextBlock Margin="0,8,0,16" TextWrapping="Wrap"
               Text="Sign in with your file user account to map your private folder and shared drives." />

    <TextBlock Text="Appliance" />
    <ComboBox x:Name="HostBox" Margin="0,4,0,12" IsEditable="True" />

    <TextBlock Text="Username" />
    <TextBox x:Name="UsernameBox" Margin="0,4,0,12" />

    <TextBlock Text="Password" />
    <PasswordBox x:Name="PasswordBox" Margin="0,4,0,12" />

    <TextBlock x:Name="ErrorText" Foreground="DarkRed" TextWrapping="Wrap" Margin="0,0,0,12" />

    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
      <Button Content="Cancel" Width="90" Margin="0,0,8,0" IsCancel="True" Click="Cancel_Click" />
      <Button x:Name="ConnectButton" Content="Connect" Width="90" IsDefault="True" Click="Connect_Click" />
    </StackPanel>
  </StackPanel>
</Window>
